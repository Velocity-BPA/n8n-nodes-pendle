{
  "name": "n8n-nodes-pendle",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for the Pendle yield tokenization protocol providing 20 resources and 200+ operations for DeFi yield trading, liquidity provision, and vePENDLE staking. Includes support for PT/YT token operations, market analytics, and multi-chain deployment.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-pendle.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-pendle#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-pendle/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "pendle",
    "defi",
    "yield",
    "tokenization",
    "ethereum",
    "arbitrum",
    "blockchain",
    "yield-trading",
    "principal-token",
    "yield-token",
    "liquidity",
    "staking",
    "vePENDLE",
    "web3",
    "smart-contracts"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PendleNetwork.credentials.js",
      "dist/credentials/PendleApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Pendle/Pendle.node.js",
      "dist/nodes/Pendle/PendleTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && npm run copy:icons",
    "copy:icons": "copyfiles -u 1 \"nodes/**/*.svg\" \"nodes/**/*.png\" dist/",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist/",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.35.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.35.0"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "ethers": "^6.11.1",
    "graphql-request": "^6.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
